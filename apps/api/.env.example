# Backend API Port
PORT=4000

# Frontend URLs for CORS and Better Auth trusted origins
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL Database Connection String
# Matches the default credentials in docker-compose.yml
DATABASE_URL=postgresql://postgres:password@localhost:5432/bpbj_db

# Better Auth Secret (Generate a random string for sessions/tokens)
BETTER_AUTH_SECRET=your_random_secret_here

BETTER_AUTH_URL=http://localhost:4000

# SMTP configuration for sending complaint replies by email
# Example Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_email@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
