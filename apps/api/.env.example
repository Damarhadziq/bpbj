PORT=4000

# PostgreSQL Database Connection String
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@localhost:5432/DB_NAME

# Frontend domain yang diizinkan untuk CORS dan Better Auth.
# Pisahkan dengan koma jika ada lebih dari satu domain.
FRONTEND_URL=https://bpbj.semarangkota.go.id

# Base URL backend/API untuk Better Auth.
BETTER_AUTH_URL=https://api.bpbj.semarangkota.go.id

# Gunakan string random panjang di production.
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Konfigurasi SMTP opsional, dipakai jika fitur email/reply diaktifkan.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password_email_anda
SMTP_FROM=user@example.com
SMTP_SECURE=false
