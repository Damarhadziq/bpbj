# Backend API Port
PORT=4000

# Frontend URLs for CORS and Better Auth trusted origins
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL Database Connection String
# Sesuaikan dengan credentials di docker-compose.yml atau database lokal Anda
DATABASE_URL=postgresql://postgres:password@localhost:5432/bpbj_db

# Better Auth Secret (Gunakan random string panjang)
BETTER_AUTH_SECRET=ganti_dengan_secret_yang_aman_dan_panjang

# Base URL untuk Better Auth
BETTER_AUTH_URL=http://localhost:4000

# Konfigurasi SMTP untuk Pengiriman Email (Opsional/Jika fitur email digunakan)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password_email_anda
SMTP_FROM=user@example.com
SMTP_SECURE=false
